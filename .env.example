# Copy to .env and adjust. Never commit your real .env.

# Ollama REST endpoint used by the LLM-judge (effect metric).
OLLAMA_HOST=http://localhost:11434
# Default local judge model (must be pulled: `ollama pull qwen2.5:7b`).
SCALPEL_JUDGE_MODEL=qwen2.5:7b

# Optional Hugging Face token (only needed for gated models, e.g. gemma-2-2b).
# HF_TOKEN=

# Where to cache captured activations and intermediate artifacts.
SCALPEL_CACHE_DIR=.scalpel_cache

# Force a device: auto | cpu | mps | cuda  (auto picks the best available).
SCALPEL_DEVICE=auto
